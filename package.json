{
  "name": "feint-supply-co",
  "version": "0.1.0",
  "description": "Autonomous Etsy store automation via OpenClaw AgentSkills",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch skills/jarvis-loop.ts",
    "loop": "tsx skills/jarvis-loop.ts",
    "research": "tsx skills/etsy-research.ts",
    "trend-mine": "tsx skills/trend-miner.ts",
    "gen": "tsx skills/listing-gen.ts",
    "design": "tsx skills/design-generator.ts",
    "publish": "tsx skills/etsy-publish.ts",
    "pod-publish": "tsx skills/pod-publisher.ts",
    "orders": "tsx skills/order-orchestrator.ts",
    "trademark": "tsx skills/trademark-hunter.ts",
    "marketing": "tsx skills/marketing-engine.ts",
    "analytics": "tsx skills/etsy-analytics.ts",
    "costs": "tsx skills/cost-dashboard.ts",
    "watchdog": "tsx skills/watchdog.ts",
    "jarvis:status": "tsx scripts/jarvis-bridge.ts status",
    "jarvis:health": "tsx scripts/jarvis-bridge.ts health",
    "jarvis:verify": "tsx scripts/jarvis-bridge.ts verify",
    "jarvis:queue": "tsx scripts/jarvis-bridge.ts queue",
    "jarvis:approval-summary": "tsx scripts/jarvis-bridge.ts approval-summary",
    "jarvis:doctor": "tsx scripts/jarvis-bridge.ts doctor",
    "jarvis:audit": "tsx scripts/jarvis-bridge.ts audit",
    "smoke": "tsx scripts/smoke-test.ts",
    "audit": "tsx scripts/audit-credentials.ts",
    "diagnose:pinterest": "tsx scripts/pinterest-diagnose.ts",
    "etsy:preflight": "tsx scripts/etsy-preflight.ts",
    "go-live": "tsx scripts/go-live.ts",
    "etsy:oauth": "tsx scripts/etsy-oauth.ts",
    "preview-digest": "tsx scripts/preview-digest.ts",
    "test:trademark": "tsx skills/trademark-hunter.ts --self-test",
    "test:printify-upload": "tsx scripts/test-printify-upload.ts",
    "test:printful-upload": "tsx scripts/test-printful-upload.ts",
    "brand:setup": "tsx scripts/brand-setup.ts",
    "brand:preview": "tsx scripts/brand-setup.ts --dry-run",
    "shop:setup": "tsx scripts/shop-setup.ts",
    "shop:refresh": "tsx scripts/shop-setup.ts --refresh-only",
    "shop:preview": "tsx scripts/shop-setup.ts --dry-run",
    "stickers": "tsx scripts/generate-sticker-pack.ts",
    "stickers:preview": "tsx scripts/generate-sticker-pack.ts --dry-run",
    "mugs": "tsx scripts/generate-mug-collection.ts",
    "mugs:preview": "tsx scripts/generate-mug-collection.ts --dry-run",
    "posters": "tsx scripts/generate-poster-collection.ts",
    "posters:preview": "tsx scripts/generate-poster-collection.ts --dry-run",
    "hoodies": "tsx scripts/generate-hoodie-collection.ts",
    "hoodies:preview": "tsx scripts/generate-hoodie-collection.ts --dry-run",
    "tshirts": "tsx scripts/generate-tshirt-collection.ts",
    "tshirts:preview": "tsx scripts/generate-tshirt-collection.ts --dry-run",
    "catalog:verify": "tsx scripts/verify-printful-catalog.ts",
    "backfill:printful": "tsx scripts/backfill-printful-products.ts",
    "igm:status": "tsx skills/igm-monitor.ts --status",
    "igm:up": "tsx skills/igm-monitor.ts --up",
    "igm:down": "tsx skills/igm-monitor.ts --down",
    "igm:restart": "tsx skills/igm-monitor.ts --restart",
    "igm:monitor": "tsx skills/igm-monitor.ts --post",
    "dashboard": "tsx monitor/dashboard-server.ts",
    "heartbeat": "tsx openclaw/jarvis-heartbeat.skill.ts",
    "orderwatch": "tsx openclaw/jarvis-order-watch.skill.ts",
    "daemon": "tsx scripts/jarvis-daemon.ts",
    "start": "tsx scripts/jarvis-daemon.ts",
    "install-daemon": "powershell -ExecutionPolicy Bypass -File scripts/install-daemon-task.ps1",
    "uninstall-daemon": "powershell -ExecutionPolicy Bypass -File scripts/install-daemon-task.ps1 -Uninstall",
    "app": "powershell -ExecutionPolicy Bypass -STA -File launcher/jarvis-app.ps1",
    "terminal": "powershell -ExecutionPolicy Bypass -File launcher/jarvis-terminal.ps1",
    "install-launcher": "powershell -ExecutionPolicy Bypass -File launcher/install-shortcut.ps1",
    "register:skills": "powershell -ExecutionPolicy Bypass -File openclaw/register-skills.ps1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@types/express": "^5.0.6",
    "better-sqlite3": "latest",
    "dotenv": "latest",
    "express": "^5.2.1",
    "node-fetch": "latest",
    "openai": "latest",
    "pdf-lib": "latest",
    "replicate": "latest",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/sharp": "^0.32.0",
    "tsx": "latest",
    "typescript": "latest"
  }
}
