ANTHROPIC_API_KEY=
REPLICATE_API_TOKEN=
ETSY_API_KEY=
ETSY_API_SECRET=
ETSY_ACCESS_TOKEN=
ETSY_REFRESH_TOKEN=
ETSY_USER_ID=
ETSY_SHOP_ID=
ETSY_SHOP_NAME=
ETSY_DEFAULT_TAXONOMY_ID=
ETSY_SHIPPING_PROFILE_ID=
ETSY_READINESS_STATE_ID=
ETSY_DEFAULT_SHOP_SECTION_ID=
# Bot display name + avatar shown on every post (overrides the webhook's own name in Discord's UI).
DISCORD_BOT_NAME=Jarvis
DISCORD_BOT_AVATAR_URL=
# Default/fallback webhook (the "command post"). Used for any stream without a dedicated webhook below.
DISCORD_WEBHOOK_URL=
# Per-channel webhooks (optional). Paste a channel's webhook URL to split that feed out;
# leave blank to keep it flowing to DISCORD_WEBHOOK_URL above.
DISCORD_HEARTBEAT_WEBHOOK_URL=
DISCORD_ANALYTICS_WEBHOOK_URL=
DISCORD_ORDERS_WEBHOOK_URL=
DISCORD_COST_WEBHOOK_URL=
DISCORD_WATCHDOG_WEBHOOK_URL=
DISCORD_IGM_WEBHOOK_URL=
DISCORD_LEGAL_WEBHOOK_URL=
# New dedicated server identifiers (for future bot-based routing).
DISCORD_FSC_COMMAND_POST_SERVER_ID=
DISCORD_FSC_COMMAND_POST_CHANNEL_ID=
DB_PATH=./data/jarvis.db
LOG_LEVEL=info
DRY_RUN=false
# Set to true to hold listings for manual approval
# before publishing to Etsy. View in dashboard.
REQUIRE_APPROVAL=true
# Max Etsy listings published per day (Etsy flags accounts
# that spike listings - keep conservative)
MAX_LISTINGS_PER_DAY=5
STORE_BRAND_NAME=Feint Supply Co.
STORE_TAGLINE=Built different. By people who were.
STORE_BRAND_THEME=veteran and former law enforcement owned, modern tech aesthetic, cybersecurity culture, quiet professional ethos, dark minimal precision design, service-to-civilian-tech pipeline
RESEARCH_INTERVAL_MINUTES=60
PUBLISH_INTERVAL_HOURS=6
MAX_LISTINGS_PER_RUN=3
# Keyword/tag expansion via the keyless Datamuse API (backfills Etsy tags up to 13).
KEYWORD_EXPANSION_ENABLED=true
# Seasonal opportunities via the keyless Nager.Date public-holidays API.
HOLIDAYS_ENABLED=true
HOLIDAYS_COUNTRY_CODE=US
HOLIDAYS_WINDOW_DAYS=90
TARGET_NICHES_FILE=./data/niches.json
OPENAI_API_KEY=
PRINTIFY_API_TOKEN=
PRINTIFY_SHOP_ID=
PRINTFUL_API_TOKEN=
IMGBB_API_KEY=
IDEOGRAM_API_KEY=
RECRAFT_API_KEY=
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
YOUTUBE_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
USPTO_API_KEY=
USPTO_TSDR_ENDPOINT=https://tsdrapi.uspto.gov/ts/cd/casestatus
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
REDDIT_ENABLED=false
LLM_ROUTING_STRATEGY=cost_optimized
DAILY_DESIGN_BUDGET_USD=10
WEEKLY_AD_BUDGET_USD=20
TRADEMARK_REVIEW_THRESHOLD=0.7
HEARTBEAT_INTERVAL_HOURS=6
HEARTBEAT_DISCORD_REPORT=true
SHOP_SETUP_REFRESH_DAYS=30
# --- Autonomous daemon (npm run daemon / install-daemon) cadences ---
ORDER_WATCH_INTERVAL_MINUTES=30
WATCHDOG_INTERVAL_MINUTES=60
# Standalone IGM snapshot cadence; 0 disables (IGM already runs inside the heartbeat).
IGM_MONITOR_INTERVAL_MINUTES=0
# --- Income Generator (IGM) passive bandwidth income ---
# Orchestrates bandwidth-sharing Docker containers (EarnApp, Honeygain, etc.).
# Requires Docker installed + the IGM bootstrap run (see https://github.com/XternA/income-generator).
# NOTE: reselling residential bandwidth may violate your ISP terms and can affect IP reputation.
IGM_ENABLED=false
# Docker executable (override if not on PATH).
IGM_DOCKER_BIN=docker
# Optional regex (case-insensitive) matching IGM container names/images. Defaults to common app keywords.
IGM_CONTAINER_FILTER=
# Latest reported cumulative earnings, summed from the individual app dashboards (manual entry).
IGM_REPORTED_EARNINGS_USD=
IGM_CURRENCY=USD
# Optional override commands for start/stop/restart (otherwise Docker acts on matched containers).
IGM_UP_COMMAND=
IGM_DOWN_COMMAND=
IGM_RESTART_COMMAND=
