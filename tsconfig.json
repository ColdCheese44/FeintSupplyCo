{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": [
      "node"
    ],
    "lib": [
      "ES2023",
      "DOM"
    ]
  },
  "include": [
    "skills/**/*.ts",
    "lib/**/*.ts",
    "scripts/**/*.ts",
    "monitor/**/*.ts",
    "openclaw/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
